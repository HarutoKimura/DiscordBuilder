# Discord bot (required from M2)
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=

# OpenAI / Codex (required from M1) — used to authenticate codex inside the sandbox:
#   printenv OPENAI_API_KEY | codex login --with-api-key
OPENAI_API_KEY=

# Base domain for generated app URLs. "localhost" for local dev;
# a real domain with wildcard DNS (*.example.com) for the VPS.
BASE_DOMAIN=localhost

# Sandbox backend. Only "local-docker" exists for now.
SANDBOX_MODE=local-docker

# Model passed to `codex exec -m`. Verify the exact model id with a real run at M1.
CODEX_MODEL=gpt-5.6-sol
