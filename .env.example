# Discord bot (required from M2)
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=

# How codex authenticates INSIDE sandbox containers:
#   chatgpt (default) — reuse the host's ChatGPT-subscription login: the host's
#                       $CODEX_HOME/auth.json (~/.codex/auth.json) is copied into
#                       each container at creation. Requires `codex login` on host.
#   api-key           — pipe OPENAI_API_KEY into `codex login --with-api-key`
#                       inside the container. For the final/production setup.
CODEX_AUTH_MODE=chatgpt

# Required only when CODEX_AUTH_MODE=api-key.
OPENAI_API_KEY=

# Base domain for generated app URLs. "localhost" for local dev;
# a real domain with wildcard DNS (*.example.com) for the VPS.
BASE_DOMAIN=localhost

# Sandbox backend. Only "local-docker" exists for now.
SANDBOX_MODE=local-docker

# Where generated apps are served from (bot only; the CLI is always local):
#   local       — http://localhost:<port>, reachable only on this machine.
#                 The private-by-default choice and therefore the default.
#   cloudflared — a Cloudflare quick tunnel per app → public HTTPS URL that
#                 community members can open. Requires `cloudflared` installed
#                 (brew install cloudflared). Quick-tunnel URLs are random and
#                 last only while the bot process stays up. ⚠️ Until the
#                 Discord OAuth gate lands (M4), these URLs have NO auth —
#                 anyone with the link can open the app. Opt in consciously.
DEPLOY_MODE=local

# Model passed to `codex exec -m`. Verify the exact model id with a real run at M1.
CODEX_MODEL=gpt-5.6-sol
